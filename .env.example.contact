# Contact Form & Email Configuration
# Copy this to .env and fill in your values

# ============================================
# EMAIL SERVICE CONFIGURATION
# ============================================

# Choose one: sendgrid, mailgun, aws-ses, nodemailer, postmark
EMAIL_SERVICE=nodemailer

# Email address to use as sender
EMAIL_FROM=noreply@speakwise.ai

# Email address where contact submissions are received
CONTACT_SUPPORT_EMAIL=support@speakwise.ai

# ============================================
# SENDGRID CONFIGURATION
# https://sendgrid.com/
# ============================================
# Get API Key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx_xxxxxxxxxxxxxxxx

# ============================================
# MAILGUN CONFIGURATION
# https://www.mailgun.com/
# ============================================
# Get API Key from: https://app.mailgun.com/app/account/security/api_keys
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxx
# Get Domain from: https://app.mailgun.com/app/domains
MAILGUN_DOMAIN=sandbox.mailgun.org

# ============================================
# AWS SES CONFIGURATION
# https://aws.amazon.com/ses
# ============================================
# AWS Region where SES is configured
AWS_REGION=us-east-1
# IAM Access Key with SES permissions
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# IAM Secret Access Key
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ============================================
# NODEMAILER / SMTP CONFIGURATION
# https://nodemailer.com/
# ============================================
# SMTP Server hostname
SMTP_HOST=smtp.gmail.com
# SMTP Server port (typically 587 for TLS, 465 for SSL)
SMTP_PORT=587
# Use TLS encryption (false for port 587, true for 465)
SMTP_SECURE=false
# SMTP username/email
SMTP_USER=your-email@gmail.com
# SMTP password (Gmail: use App Password, not account password)
SMTP_PASS=xxxx xxxx xxxx xxxx

# ============================================
# POSTMARK CONFIGURATION
# https://postmarkapp.com/
# ============================================
# Get API Token from: https://account.postmarkapp.com/servers
POSTMARK_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================
# RATE LIMITING
# ============================================
# Maximum contact submissions per IP per time window
CONTACT_RATE_LIMIT=5
# Rate limit time window in milliseconds (15 min = 900000)
CONTACT_RATE_LIMIT_WINDOW=900000

# ============================================
# OPTIONAL: CAPTCHA CONFIGURATION
# ============================================
# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI

# hCaptcha
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# ============================================
# DATABASE CONFIGURATION (if storing submissions)
# ============================================
# MongoDB connection string (if using Contact model)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ============================================
# SLACK INTEGRATION (Optional)
# Send notifications to Slack channel
# ============================================
# Slack webhook URL for contact notifications
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# ============================================
# DISCORD INTEGRATION (Optional)
# Send notifications to Discord webhook
# ============================================
# Discord webhook URL
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/123456789/abcdefghijk

# ============================================
# LOGGING
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info
# Log file path (optional)
LOG_FILE=./logs/contact-form.log

# ============================================
# CORS & SECURITY
# ============================================
# Allowed origins for API requests (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://speakwise.ai,https://www.speakwise.ai

# Enable/disable CORS
ENABLE_CORS=true

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable confirmation emails to user
SEND_CONFIRMATION_EMAIL=true
# Enable/disable admin notifications
SEND_ADMIN_NOTIFICATION=true
# Enable/disable rate limiting
ENABLE_RATE_LIMIT=true

# ============================================
# EXAMPLE: GMAIL CONFIGURATION (Recommended for development)
# ============================================
# 1. Enable 2FA in Gmail
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for Mail
# 4. Use the 16-character password below
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
#
# ============================================
# EXAMPLE: MICROSOFT OFFICE 365 CONFIGURATION
# ============================================
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@yourcompany.com
# SMTP_PASS=your-password
#
# ============================================
# TESTING EMAIL SERVICE
# ============================================
# To test email configuration, run:
# node -e "
#   const emailService = require('./services/emailService');
#   emailService.sendContactEmail({
#     name: 'Test',
#     email: 'test@example.com',
#     subject: 'Test Email',
#     message: 'This is a test email',
#     timestamp: new Date().toISOString()
#   }).then(() => console.log('Success')).catch(err => console.error(err));
# "
